# Antigravity Predictor — demo-safe defaults
DASHBOARD_PORT=80
PREDICTOR_PORT=18910
EXECUTOR_PORT=18911
FORGE_PORT=18912

MODELS_DIR=./models
DATA_DIR=./data
LOGS_DIR=./logs
FORGE_DATA_DIR=./forge_data

# Default inference path: disabled. Core client demo requires no LLM, no Hermes,
# no Anthropic, and no Ollama. Set openai_compatible/hermes_proxy/ollama/claude
# only when enrichment is intentionally configured.
SA_INFERENCE_BACKEND=disabled
HERMES_PROXY_URL=http://host.docker.internal:8645/v1
HERMES_INFERENCE_MODEL=operator-approved-model
HERMES_PROXY_API_KEY=local

# Optional advanced fallbacks only. Not required for client demo.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
ANTHROPIC_API_KEY=

SA_CONFIDENCE_THRESHOLD=0.22
SA_COOLDOWN_SECONDS=900
SA_POLL_INTERVAL=30

EXCHANGE=bybit
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
DRY_RUN=true
MIN_LONG_CONF=0.60
MIN_SHORT_CONF=0.60
POSITION_SIZE_PCT=0.02
MIN_AUC=0.54
