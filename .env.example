# ── Ports ─────────────────────────────────────────────────────────────────────
DASHBOARD_PORT=80
PREDICTOR_PORT=18910
EXECUTOR_PORT=18911

# ── Volume paths (relative to project root, or absolute) ──────────────────────
MODELS_DIR=./models
DATA_DIR=./data
LOGS_DIR=./logs

# ── Signal Agent ──────────────────────────────────────────────────────────────
# Inference backend:
#   "ollama"  → local Ollama running on the Ubuntu host (no API key needed)
#   "claude"  → Anthropic API (requires ANTHROPIC_API_KEY below)
SA_INFERENCE_BACKEND=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# Confidence threshold — must match actual model output range.
# LightGBM probabilities for this dataset are in the 0.18–0.28 range.
# 0.22 fires on clear signals; raise to 0.25 to be more selective.
SA_CONFIDENCE_THRESHOLD=0.22

# Cooldown between enrichment calls per asset (seconds). Default: 900 (15 min).
SA_COOLDOWN_SECONDS=900

# Poll interval — how often the agent checks the predictor (seconds).
SA_POLL_INTERVAL=30

# Only required if SA_INFERENCE_BACKEND=claude
ANTHROPIC_API_KEY=

# ── Exchange (Executor) ────────────────────────────────────────────────────────
EXCHANGE=bybit
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Executor behaviour ────────────────────────────────────────────────────────
# DRY_RUN=true → log signals, never place real orders
DRY_RUN=true
MIN_LONG_CONF=0.60
MIN_SHORT_CONF=0.60
POSITION_SIZE_PCT=0.02   # 2% of free USDT balance per trade

# ── Forge ─────────────────────────────────────────────────────────────────────
FORGE_PORT=18912
FORGE_DATA_DIR=./forge_data

# ── Retrain ───────────────────────────────────────────────────────────────────
MIN_AUC=0.54
