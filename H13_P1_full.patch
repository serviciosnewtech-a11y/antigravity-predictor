+        h = max(o, c) * 1.001
+        l = min(o, c) * 0.999
+        v = 10.0 + (i % 5)
+        candles.append({"time": 1_700_000_000 + i * 900, "open": o, "high": h, "low": l, "close": c, "volume": v})
